                  "});",
                  "pm.test('Returns created user with id and email', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('number');",
                  "    pm.expect(json.email).to.eql(pm.environment.get('test_email'));",
                  "    pm.environment.set('created_user_id', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/users/?email={{test_email}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                ""
              ],
              "query": [
                {
                  "key": "email",
                  "value": "{{test_email}}"
                }
              ]
            }
          }
        },
