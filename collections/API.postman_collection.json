    {
      "name": "Root",
      "item": [
        {
          "name": "GET / - returns running message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns running message', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.eql('API playground is running');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/"
          }
        }
      ]
    },
