        {
          "name": "GET /openapi.json - returns valid OpenAPI schema",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "pm.test('Response is valid OpenAPI schema', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.openapi).to.be.a('string').and.match(/^3\\./);",
                  "    pm.expect(json.info).to.be.an('object');",
                  "    pm.expect(json.paths).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/openapi.json"
          }
        },
